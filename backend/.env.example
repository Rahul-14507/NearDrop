# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local dev — no extra setup required)
DATABASE_URL=sqlite+aiosqlite:///./neardrop.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/neardrop

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=neardrop-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# ── Azure Speech Services (TTS + STT) ────────────────────────────────────────
# Create resource at portal.azure.com → "Speech" service
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# ── Azure Maps ────────────────────────────────────────────────────────────────
# Create resource at portal.azure.com → "Azure Maps Account"
AZURE_MAPS_SUBSCRIPTION_KEY=

# ── Azure Communication Services ─────────────────────────────────────────────
# Create resource at portal.azure.com → "Communication Services"
# Connection string from Keys & Endpoint section
AZURE_COMMUNICATION_CONNECTION_STRING=
# Purchased/ported phone number for outbound PSTN calls (E.164 format)
AZURE_COMMUNICATION_PHONE_NUMBER=+1XXXXXXXXXX

# ── Dispatcher Frontend ───────────────────────────────────────────────────────
# Must match where Next.js is served from in production
NEXT_PUBLIC_API_URL=http://localhost:8000
# Azure Maps key for the dispatcher hub map (can be same as AZURE_MAPS_SUBSCRIPTION_KEY)
NEXT_PUBLIC_AZURE_MAPS_KEY=

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=
# Full URL of the Next.js app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000
