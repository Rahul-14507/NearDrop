# ─── Database ───────────────────────────────────────────────
# Azure PostgreSQL Flexible Server connection string
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:5432/neardrop?ssl=require
# For local Docker dev, use: postgresql+asyncpg://neardrop:neardrop@db:5432/neardrop
# For local SQLite dev, use: sqlite+aiosqlite:///./neardrop.db
DATABASE_URL=sqlite+aiosqlite:///./neardrop.db

# ─── Auth ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_DAYS=30

# ─── Azure Speech Services ──────────────────────────────────
# Portal: portal.azure.com → Speech Service → Keys and Endpoint
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=                # e.g. eastus, centralindia

# ─── Azure Maps ─────────────────────────────────────────────
# Portal: portal.azure.com → Azure Maps Account → Authentication
AZURE_MAPS_SUBSCRIPTION_KEY=

# ─── Azure Communication Services ───────────────────────────
# Portal: portal.azure.com → Communication Services → Keys
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_COMMUNICATION_SENDER_PHONE=   # Format: +1XXXXXXXXXX (your ACS number)

# ─── Firebase Cloud Messaging ───────────────────────────────
# Console: console.firebase.google.com → Project Settings → Service Accounts
# → Generate new private key → paste entire JSON content below as one line
FIREBASE_SERVICE_ACCOUNT_JSON=

# ─── App Settings ───────────────────────────────────────────
ENVIRONMENT=development             # development | production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
